generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  name            String
  genre           String
  email           String          @unique
  emailVerified   Boolean         @default(false)
  image           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  birth_date      DateTime
  emergency_phone String
  phone           String
  type            UserType
  weight          Decimal         @db.Decimal(5, 2)
  accounts        Account[]
  instructor      Instructor?
  sessions        Session[]
  student         Student?
  trainingGroups  TrainingGroup[]
  enrollments     Enrollment[]
  publications    Publication[]

  @@map("user")
}

model Student {
  id     String @id
  belt   Belt
  stripe Int
  user   User   @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("student")
}

model Instructor {
  id                   String  @id
  belt                 Belt
  stripe               Int
  commissionPerStudent Decimal @db.Decimal(6, 2)
  user                 User    @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("instructor")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Category {
  id           String  @id @default(cuid())
  age_group    String  @db.VarChar(30)
  description  String? @db.VarChar(1255)
  name         String
  weight_range String  @db.VarChar(30)

  @@map("category")
}
model Publication {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt             DateTime  @updatedAt
  title        String
  content      String
  instructorId String   // Campo que guarda o ID do instrutor
  instructor   User     @relation(fields: [instructorId], references: [id])
  
  // SE ESTIVER ASSIM ABAIXO, VOCÊ PRECISA REMOVER O 'name' OU ADICIONAR O @default("")/fazer opcional:
  // name         String   <-- Se esta linha existir e não for opcional, o Prisma vai reclamar que ela falta.
}

model Plan {
  id          String  @id @default(cuid())
  title       String  @db.VarChar(255)
  period      String  @db.VarChar(255)
  description String? @db.Text
  price       Decimal @db.Decimal(6, 2)

  @@map("plan")
}

model Branch {
  id String @id @default(cuid())

  street       String @db.VarChar(255)
  neighborhood String @db.VarChar(255)
  number       Int
  CEP          String @db.VarChar(8)
  city         String @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classGroups TrainingGroup[]

  @@map("branch")
}

//Grupo de Treinamento/Turma
model TrainingGroup { 
  id              String @id @default(cuid())
  name            String @default("")
  studentCapacity Int    @map("student_count") @db.SmallInt  // capacidade máxima de alunos por turma

  branchId String? @map("branch_id") //ID da filial. O símbolo ? indica que este campo é opcional (uma turma pode não ter filial vinculada).
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade) //Se a filial dona deste grupo for deletada, este grupo de treinamento também será apagado automaticamente

  instructorId String @map("instructor_id") //ID do instrutor responsável por esta turma. Este campo é obrigatório, ou seja, uma turma deve ter um instrutor vinculado.
  instructor   User   @relation(fields: [instructorId], references: [id], onDelete: Restrict) //Vincula a turma a um usuário instrutor

  createdAt   DateTime     @default(now()) //Data de criação do grupo de treinamento, definida automaticamente para o momento em que o registro é criado.
  updatedAt   DateTime     @updatedAt      //Data de atualização do grupo de treinamento, atualizada automaticamente sempre que o registro é modificado.
  schedules   Schedule[]                   //Relacionamento um-para-muitos com a entidade Schedule, indicando que um grupo de treinamento pode ter vários horários de aula.
  enrollments Enrollment[]                  //Relacionamento um-para-muitos com a entidade Enrollment, indicando que um grupo de treinamento pode ter várias matrículas de alunos.

  @@index([branchId])
  @@index([instructorId])
  @@map("training_group")
}

model Schedule {
  id String @id @default(cuid())

  trainingGroupId String        @map("training_group_id")
  trainingGroup   TrainingGroup @relation(fields: [trainingGroupId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek @map("day_of_week")
  startTime DateTime  @db.Time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]

  @@index([trainingGroupId])
  @@map("schedule")
}

model Enrollment {
  id String @id @default(cuid())

  enrollmentDate DateTime @default(now()) @map("enrollment_date") // data_matricula

  trainingGroupId String        @map("training_group_id")
  trainingGroup   TrainingGroup @relation(fields: [trainingGroupId], references: [id], onDelete: Cascade)

  studentId String @map("student_id")
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  scheduleId String   @map("schedule_id")
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, trainingGroupId, scheduleId])
  @@index([trainingGroupId])
  @@index([studentId])
  @@index([scheduleId])
  @@map("enrollment")
}

enum UserType {
  Student
  Instructor
  Admin
}

enum Belt {
  WHITE
  GRAY
  YELLOW
  ORANGE
  GREEN
  BLUE
  PURPLE
  BROWN
  BLACK
  CORAL
  RED
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}
